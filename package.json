    "audit:secrets": "grep -r 'service_role\\|RESEND_API\\|MP_ACCESS_TOKEN' dist/ && echo 'ALERTA: SECRET ENCONTRADO NO BUNDLE!' || echo 'OK - Nenhum secret sensivel no bundle'",
    "audit:secrets:win": "findstr /r /s \"service_role RESEND_API MP_ACCESS_TOKEN\" dist\\ && echo ALERTA: SECRET ENCONTRADO! || echo OK - Nenhum secret sensivel no bundle",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.100.10",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-hot-toast": "^2.5.0",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
